# matchpoint environment variables
# Copy to `.env` and fill in from your Supabase project (Settings -> API).
# Only the public (anon) key belongs in the app — it is safe to ship.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NEVER add the service_role key here or anywhere in the app.
# It bypasses Row Level Security and must stay server-side only.
