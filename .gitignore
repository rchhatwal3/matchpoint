# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (NEVER commit real keys; .env.example is tracked)
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# Supabase CLI link state
supabase/.temp/

# graphify — keep graph.json + report tracked; ignore machine-specific/build artifacts
graphify-out/cache/
graphify-out/graph.html
graphify-out/.graphify_*
graphify-out/cost.json

# test coverage
coverage/
